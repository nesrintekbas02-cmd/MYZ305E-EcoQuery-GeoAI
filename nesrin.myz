              "                    background-color: var(--colab-primary-surface-color, white);\n",
              "                }\n",
              "\n",
              "                .geemap-colab .jupyter-button {\n",
              "                    --jp-layout-color3: var(--colab-primary-surface-color, white);\n",
              "                }\n",
              "            </style>\n",
              "            "
            ]
          },
          "metadata": {}
        },
        {
          "output_type": "stream",
          "name": "stdout",
          "text": [
            "EcoQuery Ajanı (Gemini 2.5 Flash modeliyle) başarıyla oluşturuldu ve göreve hazır!\n"
          ]
        }
      ]
    },
    {
      "cell_type": "code",
      "source": [
        "# Ajanımıza sorumuzu soruyoruz\n",
        "soru = \"Kahramanmaraş merkez (enlem: 37.57, boylam: 36.92) civarında 2023 yılı yaz aylarında bitki örtüsü nasıldı? Analiz eder misin?\"\n",
        "\n",
        "print(f\"Kullanıcı Sorusu: {soru}\\n\")\n",
        "print(\"EcoQuery Düşünüyor ve Analiz Ediyor...\\n\")\n",
        "print(\"-\" * 50)\n",
        "\n",
        "# Ajanı çalıştırıyoruz\n",
        "yanit = eco_query_ajani.invoke({\"input\": soru})\n",
        "\n",
        "print(\"-\" * 50)\n",
        "print(f\"\\nEcoQuery'nin Yanıtı:\\n{yanit['output']}\")"
      ],
      "metadata": {
